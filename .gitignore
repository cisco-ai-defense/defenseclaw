.DS_Store

# Local environment files
.env
.env.*
!.env.example

# Generated config copies (canonical source: internal/configs/providers.json)
extensions/defenseclaw/src/providers.json

# Synced embed target for the OpenClaw plugin (regenerated by `make
# sync-openclaw-extension`; canonical source is extensions/defenseclaw/).
internal/gateway/connector/openclaw_extension/*
!internal/gateway/connector/openclaw_extension/.placeholder

# Editor and IDE metadata
.idea/
.vscode/
.cursor/
.windsurf/
*.swp
*.swo
*~

# Go build and test artifacts
bin/
dist/
build/
coverage.out
cover.out
*.coverprofile
*.test
.gocache/
.gomodcache/

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Bundled data is disposable build staging generated by make _bundle-data.
cli/defenseclaw/_data/
!cli/defenseclaw/_data/
cli/defenseclaw/_data/*
!cli/defenseclaw/_data/config/
cli/defenseclaw/_data/config/*

# Python venv
.venv/

# Local binaries
/defenseclaw
/defenseclaw-*
/custom-scanner

# Collector builder output

# Node.js
node_modules/

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage*.xml

# Archive (historical snapshots — not maintained)
/_archive/

# Private keys and certificates — NEVER commit
*.pem
*.key
*.p12
*.pfx


# E2E local-only setup scripts (documented in docs/E2E.md)
scripts/provision-*
scripts/e2e-*-session*
.worktrees/

# Temporary files and directories — local-only scratch artifacts.
tmp/
.tmp/
temp/
*.tmp
*.temp
*.bak
*.orig

# Telemetry updater staging directories.
/telemetry-upstream-update-*/

# Reproducible telemetry reports and test corpora. The registry compiler
# validates these in memory and can materialize them for release/debug work;
# they are not source or runtime package inputs.
/schemas/telemetry/generated/catalog.md
/schemas/telemetry/generated/compatibility/inbound-otlp.json
/schemas/telemetry/generated/examples/
/schemas/telemetry/generated/otlp-fixtures/

# Runtime telemetry JSON is generated in memory and tracked only as canonical
# gzip under schemas/telemetry/runtime/. Release staging expands exact raw JSON.
/schemas/telemetry/generated/telemetry.schema.json
/schemas/telemetry/generated/catalog.json
/schemas/telemetry/generated/compatibility/galileo-rich-v2.json
/schemas/telemetry/generated/compatibility/local-observability-v1.json
/schemas/telemetry/generated/compatibility/openinference-v1.json
/schemas/telemetry/generated/compatibility/v7-exporter-selection.json

# Full Go symbol-table snapshots duplicated generated declarations and grew by
# ~11k lines per compiler epoch. Determinism is enforced from the authored
# registry and generated Go output; Git history retains prior epochs.
/schemas/telemetry/v8/baselines/go-symbol-table/

# Local-only TUI testing notes and panel walkthroughs. These are
# personal/agent scratch docs and should not be source-controlled.
docs/testing/

# Playwright session/console logs and outputs (transient debug artifacts).
.playwright-cli/
.playwright-mcp/
output/playwright/

# Local-only screenshots from dashboard / TUI debugging passes. Add a
# specific PNG to git only when it ships in docs/.
/*.png

# Agent memory / context files — local-only, not versioned.
# Each contributor's AI assistant (Claude, Codex, Cursor, etc.) loads
# these from disk; keeping them out of git prevents cross-contamination
# between personal workflow notes and the project's canonical docs.
AGENTS.md
CLAUDE.md
agent-out/

# Local PR365 follow-up session scratch notes. Keep the canonical audit
# reports and non-markdown follow-up artifacts reviewable, but do not
# publish per-session markdown working notes in the PR.
.audit/pr365-followups/session*.md

# Local security-tooling working directories — each contributor's
# Avarice / DeepSec runs drop campaign data, findings, and node_modules
# under these trees. Keep them out of git so per-machine scan artifacts
# never leak into PRs or the published audit trail. security_report/
# holds ad-hoc on-disk review writeups produced by the same tooling.
.avarice/
.deepsec/
security_report/

# Local smoke-test scratch directory used by manual REPL/curl runs
# against an isolated DEFENSECLAW_HOME. Holds bin/, home/, logs/, and
# operator-authored sweep-*.sh helpers — none of these are project
# source.
.smoke/

# Manual run artifacts (manual-*/, plan outputs) from local harness runs.
# Scratch only, not project source.
outputs/

# Protoc-gen-* tool binaries used by `make proto` (pinned locally so
# regeneration does not depend on the operator's global GOPATH/bin).
.tools/

# UDS sockets created by the local IPC server or its e2e tests.
*.sock

# Locally built mock AI Defense ingest server (scripts/build-managed-bundle.sh
# / manual testing). Compiled artifact — never commit.
/mock-aid-ingest

# Local native-Windows manual acceptance walkthrough.
/WINDOWS_NATIVE_MANUAL_TEST.md
