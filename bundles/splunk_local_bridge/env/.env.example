# Splunk container runtime contract
# The same tag is expected to resolve on both linux/amd64 and linux/arm64.
SPLUNK_IMAGE=splunk/splunk-claw-bridge:10.2.0
SPLUNK_START_ARGS=--accept-license
SPLUNK_LICENSE_URI=Free
SPLUNK_GENERAL_TERMS=--accept-sgt-current-at-splunk-com
SPLUNK_PASSWORD=DefenseClawLocalMode1!
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000001

# DefenseClaw local ingest contract
DEFENSECLAW_HEC_URL=http://127.0.0.1:8088/services/collector/event
DEFENSECLAW_HEC_TOKEN=00000000-0000-0000-0000-000000000001
DEFENSECLAW_INDEX=defenseclaw_local
DEFENSECLAW_SOURCETYPE=defenseclaw:json
DEFENSECLAW_SOURCE=defenseclaw
DEFENSECLAW_INTEGRATION_ENABLED=false
DEFENSECLAW_REF=unknown

# NemoClaw compatibility baseline
NEMOCLAW_REF=36fa334
NEMOCLAW_LOCAL_PROVIDER=ollama
NEMOCLAW_LOCAL_MODEL=qwen2.5:0.5b
NEMOCLAW_LOCAL_SANDBOX_NAME=splunk-claw-local
NEMOCLAW_LOCAL_POLICY_MODE=skip
NEMOCLAW_LOCAL_OLLAMA_HOST=0.0.0.0:11434

# Product telemetry follows a default-on, explicit opt-out model.
# Public repo defaults still use placeholder destination values and must fail closed until a named environment injects real ones.
PHONE_HOME_ENABLED=true
PHONE_HOME_HEC_URL=https://example.invalid/services/collector/event
PHONE_HOME_HEC_TOKEN=replace-me-in-named-environments

# Optional local S3 export bridge for demo/dev handoff.
# Disabled by default. When enabled, the sidecar queries local Splunk and writes
# normalized JSONL.GZ batches plus manifests to S3-compatible storage.
S3_EXPORT_ENABLED=false
S3_EXPORT_ONCE=false
S3_BUCKET=
S3_PREFIX=agentwatch/defenseclaw
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_ENDPOINT_URL=
S3_SSE=AES256
S3_EXPORT_INTERVAL_SECONDS=60
S3_EXPORT_WINDOW_SECONDS=300
S3_EXPORT_LOOKBACK_SECONDS=30
TENANT_ID=c3-demo-tenant
WORKSPACE_ID=workspace-demo
DEPLOYMENT_ENVIRONMENT=local
