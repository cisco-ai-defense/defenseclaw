    {
      "type": "stat",
      "title": "Hook errors (1h)",
      "description": "Gateway errors during the selected range. OpenClaw HILT timeout metrics appear when that connector runs in action mode.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_gateway_errors_total[$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "HILT unsupported (1h)",
      "description": "hilt_unsupported \u2014 the connector accepted the prompt but the operator surface (chat client) cannot render an approval UI. Often indicates a misconfigured connector.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations \u2192 internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\", result=\"rejected\"}[$__range])) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Hook-mode approval funnel ($__range)",
      "description": "Approval funnel using hook telemetry. confirm/block/allow from inspect evaluations; shadow blocks from would_block outcomes. OpenClaw HILT-specific counters populate when that connector runs in action mode.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"confirm\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "confirm verdicts",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[$__range])) or vector(0)",
          "legendFormat": "shadow blocks (observe)",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"block\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "blocks",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"allow\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "allows",
          "refId": "D",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "orientation": "horizontal"
      }
    },
    {
