      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "clamp_min((sum(increase(defenseclaw_approval_lifecycle_total{connector=~\"$connector\",surface=\"chat\",result=\"pending\"}[5m])) or vector(0)) - (sum(increase(defenseclaw_approval_lifecycle_total{connector=~\"$connector\",surface=\"chat\",result=~\"approved|denied|expired|cancelled\"}[5m])) or vector(0)), 0)",
          "refId": "A",
          "instant": true
        }
