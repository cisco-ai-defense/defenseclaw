              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "HILT unsupported (1h)",
      "description": "hilt_unsupported — the connector accepted the prompt but the operator surface (chat client) cannot render an approval UI. Often indicates a misconfigured connector.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\", guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"hilt_unsupported\"}[1h])) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Hook-mode approval funnel ($__range)",
      "description": "Approval funnel using hook telemetry. confirm/block/allow from inspect evaluations; shadow blocks from would_block outcomes. OpenClaw HILT-specific counters populate when that connector runs in action mode.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"confirm\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "confirm verdicts",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[$__range])) or vector(0)",
          "legendFormat": "shadow blocks (observe)",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"block\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "blocks",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action=\"allow\", tool=~\"$connector:.*\"}[$__range])) or vector(0)",
          "legendFormat": "allows",
          "refId": "D",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "orientation": "horizontal"
      }
    },
    {
      "type": "row",
      "title": "Chat HILT (openclaw:hilt)",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Chat HILT status mix over time",
      "description": "Status counters from RecordGuardrailEvaluation(\"openclaw:hilt\", action). Stack shows requested vs approved/denied/timeout/unsupported simultaneously so you can see the operator-response funnel.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (guardrail_action_taken) (rate(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\", guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=~\"approval_requested|approval_approved|approval_denied|approval_timeout|hilt_unsupported\"}[$__rate_interval])) or on() vector(0)",
          "legendFormat": "{{guardrail_action_taken}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Chat HILT approval-vs-denial rate (1h rolling)",
      "description": "approved / (approved + denied + timeout). Slow drift toward 0 means operators are denying more often — investigate via the verdict-categories panel on Security.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(sum(rate(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\", guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=\"approval_approved\"}[1h])) or vector(0)) / clamp_min((sum(rate(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\", guardrail_scanner=\"openclaw:hilt\", guardrail_action_taken=~\"approval_approved|approval_denied|approval_timeout\"}[1h])) or vector(0)), 0.0001)",
          "legendFormat": "approval rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "type": "stat",
      "title": "HITL backlog delta (5m)",
      "description": "Five-minute request/completion delta, not a live in-flight gauge. Positive means more approval requests than terminal decisions arrived during the window; zero does not prove an older request is no longer pending.\n\ncovered_by:\n  - defenseclaw_guardrail_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "clamp_min((sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\",guardrail_action_taken=\"approval_requested\"}[5m])) or vector(0)) - (sum(increase(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\",guardrail_action_taken=~\"approval_approved|approval_denied|approval_timeout\"}[5m])) or vector(0)), 0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
