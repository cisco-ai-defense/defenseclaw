    {
      "type": "timeseries",
      "title": "Chat HILT status mix over time",
      "description": "Generated approval lifecycle events for the chat HILT surface. Stack preserves pending, policy outcomes, operator cancellation, expiry, unavailable sessions, and delivery failures without treating approval states as guardrail decisions.\n\ncovered_by:\n  - defenseclaw_approval_lifecycle → internal/gateway/hilt_observability_v8.go (generated canonical metric)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(defenseclaw_approval_lifecycle_total{connector=~\"$connector\", surface=\"chat\", result=~\"pending|approved|denied|expired|cancelled|unavailable|delivery_failed\"}[$__rate_interval])) or on() vector(0)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Chat HILT approval-vs-denial rate (1h rolling)",
      "description": "approved / (approved + denied + expired) for policy-complete chat HILT requests. Technical cancellation and delivery failures remain visible in the neighboring panels without distorting the operator decision ratio.\n\ncovered_by:\n  - defenseclaw_approval_lifecycle → internal/gateway/hilt_observability_v8.go (generated canonical metric)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "(sum(rate(defenseclaw_approval_lifecycle_total{connector=~\"$connector\", surface=\"chat\", result=\"approved\"}[1h])) or vector(0)) / clamp_min((sum(rate(defenseclaw_approval_lifecycle_total{connector=~\"$connector\", surface=\"chat\", result=~\"approved|denied|expired\"}[1h])) or vector(0)), 0.0001)",
          "legendFormat": "approval rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "type": "stat",
      "title": "HITL backlog delta (5m)",
