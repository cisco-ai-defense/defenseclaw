    {
      "type": "stat",
      "title": "Hook errors (1h)",
      "description": "Gateway errors during the selected range. OpenClaw HILT timeout metrics appear when that connector runs in action mode.\n\ncovered_by:\n  - defenseclaw_gateway_errors → internal/telemetry/gateway_events.go (EventError)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_gateway_errors_total[1h])) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
