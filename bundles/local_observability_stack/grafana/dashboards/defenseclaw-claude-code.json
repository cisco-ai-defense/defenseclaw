{
  "annotations": {
    "list": [
      {
        "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\"}",
        "iconColor": "red",
        "name": "Firing alerts",
        "tagKeys": "alertname,severity",
        "titleFormat": "{{alertname}} - {{severity}}",
        "useValueForTime": false
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {"title": "Overview", "type": "link", "url": "/d/defenseclaw-overview", "icon": "external link", "targetBlank": false},
    {"title": "Security", "type": "link", "url": "/d/defenseclaw-security", "icon": "external link", "targetBlank": false},
    {"title": "Codex", "type": "link", "url": "/d/defenseclaw-codex", "icon": "external link", "targetBlank": false}
  ],
  "liveNow": false,
  "panels": [
    {"type": "row", "title": "Claude Code hooks", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},
    {
      "type": "stat",
      "title": "Hooks / min",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_claude_code_hook_invocations_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Blocks / min",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_claude_code_blocks_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "type": "stat",
      "title": "Would-blocks / min",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_claude_code_would_blocks_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Hook p95 latency",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(defenseclaw_claude_code_hook_latency_milliseconds_bucket[5m]))) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1000}, {"color": "red", "value": 5000}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Component scans / min",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_claude_code_component_scans_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "timeseries",
      "title": "Hook decisions by event",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (hook_event, action) (rate(defenseclaw_claude_code_hook_invocations_total[5m]))", "legendFormat": "{{hook_event}} {{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Blocks and would-blocks",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (hook_event, severity) (rate(defenseclaw_claude_code_blocks_total[5m]))", "legendFormat": "blocked {{hook_event}} {{severity}}", "refId": "A"},
        {"expr": "sum by (hook_event, severity) (rate(defenseclaw_claude_code_would_blocks_total[5m]))", "legendFormat": "would-block {{hook_event}} {{severity}}", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by event",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, hook_event) (rate(defenseclaw_claude_code_hook_latency_milliseconds_bucket[5m])))", "legendFormat": "{{hook_event}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "type": "timeseries",
      "title": "Component scans by result",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (component, result) (max_over_time(defenseclaw_claude_code_component_scans_total[$__range]))", "legendFormat": "{{component}} {{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "logs",
      "title": "Recent Claude Code hook events",
      "datasource": {"type": "loki", "uid": "defenseclaw-loki"},
      "gridPos": {"x": 0, "y": 21, "w": 24, "h": 8},
      "targets": [{"expr": "{service_namespace=\"ai-governance\"} |= \"\\\"agent_id\\\":\\\"claude-code\\\"\"", "refId": "A"}],
      "options": {"showTime": true, "showLabels": false, "wrapLogMessage": true}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["defenseclaw", "claude-code"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "DefenseClaw Claude Code",
  "uid": "defenseclaw-claude-code",
  "version": 1
}
