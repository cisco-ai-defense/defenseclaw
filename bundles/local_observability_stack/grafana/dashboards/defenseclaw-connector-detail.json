{
  "annotations": {
    "list": []
  },
  "description": "Per-connector deep-dive driven by the $connector variable. Open from the Connectors overview by clicking any connector name. Panels use the canonical source or connector identity carried by each signal.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {
      "title": "Agent Activity (Live)",
      "type": "link",
      "url": "/d/defenseclaw-activity?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Connectors overview",
      "type": "link",
      "url": "/d/defenseclaw-connectors?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Verdicts",
      "type": "link",
      "url": "/d/defenseclaw-security?${__url_time_range}&${connector:queryparam}&${stage:queryparam}&${action:queryparam}&${severity:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "HITL",
      "type": "link",
      "url": "/d/defenseclaw-hitl?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Findings",
      "type": "link",
      "url": "/d/defenseclaw-findings?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Agent identity",
      "type": "link",
      "url": "/d/defenseclaw-agent-identity?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/defenseclaw-overview?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "description": "Connector to deep-dive on. Sourced from defenseclaw_connector_hook_invocations_total{connector} so hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) appear — defenseclaw_otel_ingest_records_total{source} only covers connectors that push native OTLP and would silently exclude every hook-only connector.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
        "query": {
          "query": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "claudecode",
          "value": "claudecode",
          "selected": true
        },
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Connector $connector — at a glance",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Activity / min",
      "description": "OTLP records/min when the connector pushes native OTLP, otherwise falls back to hook invocations/min. Hook-only connectors (cursor, hermes, copilot, geminicli, windsurf) populate the second branch.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_otel_ingest_records_total{source=\"$connector\"}[5m])) * 60 or sum(rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Hooks / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Reported tokens / min",
      "description": "Connector-attributed token rate reported upstream. This is a five-minute window-average rate: established series use counter delta divided by the window; a series first published inside the window uses its latest cumulative completion value divided by the window. It is not an instantaneous rate. Hook-only connectors may not report token usage; no series is an explicit unavailable state, not a measured zero.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum((((increase(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[5m]) or (last_over_time(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[5m]) * 0)) and defenseclaw_agent_token_usage_total{connector=\"$connector\"} offset 5m) or (last_over_time(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[5m]) unless defenseclaw_agent_token_usage_total{connector=\"$connector\"} offset 5m))) / 300 * 60",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "Not reported",
          "unit": "suffix: tokens/min"
        }
      }
    },
    {
      "type": "stat",
      "title": "OTLP silence (s)",
      "description": "Seconds since the last accepted OTel batch for a native-OTLP connector. Hook-only connectors intentionally show no series because a sampled counter cannot provide an honest last-event timestamp. >600s triggers DefenseClawConnectorTelemetrySilent for connectors that have emitted OTLP.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - max(defenseclaw_otel_ingest_last_seen_ts_seconds{source=\"$connector\"})",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Hook latency p95 (ms)",
      "description": "95th percentile hook processing latency for this connector.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=\"$connector\"}[5m])) by (le)) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Evaluations / min",
      "description": "Guardrail evaluations / min for this connector, filtered by the first-class connector label on defenseclaw_inspect_evaluations_total. Native-OTLP-push counts remain visible in the OTLP ingest row below.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "row",
      "title": "Connector event rates",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Hook invocations / sec by event_type",
      "description": "Hook invocation rate for the selected connector, split by hook lifecycle event.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Hook outcomes / sec by event_type",
      "description": "Hook outcome rate for the selected connector. Severity/result labels live on the hook outcome metric.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(defenseclaw_connector_hook_outcome_total{connector=\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "row",
      "title": "Hooks",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Hook invocations / sec by event_type x result",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type, result) (rate(defenseclaw_connector_hook_invocations_total{connector=\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{event_type}} / {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by event_type",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=\"$connector\"}[$__rate_interval])))",
          "legendFormat": "{{event_type}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "row",
      "title": "GenAI tokens + LLM duration (LLM-proxy connectors only)",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Tokens / sec by direction x model",
      "description": "Window-average reported token rate by model and direction. Established series use counter delta divided by the window; a series first published inside the window uses its latest cumulative completion value divided by the window. It is not an instantaneous rate; absent series mean token usage was not reported.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (kind, gen_ai_request_model) ((((increase(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[$__rate_interval]) or (last_over_time(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[$__rate_interval]) * 0)) and defenseclaw_agent_token_usage_total{connector=\"$connector\"} offset $__rate_interval) or (last_over_time(defenseclaw_agent_token_usage_total{connector=\"$connector\"}[$__rate_interval]) unless defenseclaw_agent_token_usage_total{connector=\"$connector\"} offset $__rate_interval))) / ($__rate_interval_ms / 1000)",
          "legendFormat": "{{gen_ai_request_model}} / {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Not reported",
          "unit": "suffix: tokens/sec"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "LLM span duration p50/p95/p99 (ms)",
      "description": "Duration of connector-attributed model operation spans. No series means the connector did not emit eligible operation spans.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(defenseclaw_agent_span_duration_milliseconds_bucket{connector=\"$connector\",gen_ai_operation_name=~\"chat|generate_content|text_completion\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(defenseclaw_agent_span_duration_milliseconds_bucket{connector=\"$connector\",gen_ai_operation_name=~\"chat|generate_content|text_completion\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(defenseclaw_agent_span_duration_milliseconds_bucket{connector=\"$connector\",gen_ai_operation_name=~\"chat|generate_content|text_completion\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Not reported",
          "unit": "ms"
        }
      }
    },
    {
      "type": "row",
      "title": "Verdicts (global)",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Verdicts by action (stacked)",
      "description": "Verdict action mix: allow / warn / alert / confirm / block. In observe mode every action is reported as allow — a rule that would block is reclassified to allow with would_block=true, so use the Would-block panel to the right to see shadow blocks.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Evaluations by hook event",
      "description": "Which hook lifecycle event triggered each guardrail evaluation for this connector.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (tool) (rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Would-block / min (observe shadow blocks)",
      "description": "Rules that WOULD have blocked but were allowed because this connector runs in observe mode (would_block=true on defenseclaw_connector_hook_outcome_total). This is the observe-mode shadow-block signal — it stays empty in action mode (real blocks show under action=block instead). Split by severity. Filtered by $connector.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (severity) (rate(defenseclaw_connector_hook_outcome_total{connector=\"$connector\", would_block=\"true\"}[$__rate_interval])) * 60 or on() vector(0)",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Policy evaluation signals",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Non-allow evaluations",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{action!~\"allow|none\", connector=~\"$connector\"}[$__range])) or vector(0)",
          "legendFormat": "non-allow",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=\"$connector\"}[$__rate_interval])))",
          "legendFormat": "hook p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "row",
      "title": "Tools + findings",
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Top tools (1h)",
      "description": "Most-invoked tools in the last hour from canonical tool.invocation.completed records.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 51,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(15, sum by (tool_name) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | connector=\"$connector\" | event_name=\"tool.invocation.completed\" | label_format tool_name=\"{{.body_gen_ai_tool_name}}\" [1h])))",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          },
          "queryType": "instant"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "calls/1h"
            }
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Top findings by rule (24h)",
      "description": "Scanner findings for the selected connector, aggregated by rule across all scanners.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 51,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(20, sort_desc(sum by (scanner, rule_id, severity) (increase(defenseclaw_scan_findings_by_rule_total{connector=\"$connector\"}[24h]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "findings/24h"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Recent connector events (Loki)",
      "gridPos": {
        "x": 0,
        "y": 59,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "$connector — canonical events",
      "description": "All canonical gateway log events carrying this connector in the v8 envelope.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 60,
        "w": 24,
        "h": 14
      },
      "timeFrom": "1h",
