{
  "annotations": {
    "list": []
  },
  "description": "Canonical v8 correlation surface: agent.id × agent.instance_id × sidecar.instance_id, identity churn, on-demand agent discovery confidence, continuous AI inventory rollups, and per-connector identity-presence rate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {
      "title": "Agent Activity (Live)",
      "type": "link",
      "url": "/d/defenseclaw-activity?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/defenseclaw-overview?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Hook Connectors",
      "type": "link",
      "url": "/d/defenseclaw-connectors?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Connector detail",
      "type": "link",
      "url": "/d/defenseclaw-connector-detail?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "AI discovery",
      "type": "link",
      "url": "/d/defenseclaw-ai-discovery?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "type": "custom",
        "query": "openclaw,codex,claudecode,zeptoclaw,hermes,cursor,windsurf,geminicli,copilot,openhands,antigravity,opencode,omnigent",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "openclaw",
            "value": "openclaw"
          },
          {
            "text": "codex",
            "value": "codex"
          },
          {
            "text": "claudecode",
            "value": "claudecode"
          },
          {
            "text": "zeptoclaw",
            "value": "zeptoclaw"
          },
          {
            "text": "hermes",
            "value": "hermes"
          },
          {
            "text": "cursor",
            "value": "cursor"
          },
          {
            "text": "windsurf",
            "value": "windsurf"
          },
          {
            "text": "geminicli",
            "value": "geminicli"
          },
          {
            "text": "copilot",
            "value": "copilot"
          },
          {
            "text": "openhands",
            "value": "openhands"
          },
          {
            "text": "antigravity",
            "value": "antigravity"
          },
          {
            "text": "opencode",
            "value": "opencode"
          },
          {
            "text": "omnigent",
            "value": "omnigent"
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Identity at a glance",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Active agent.id (5m)",
      "description": "Distinct connector + gen_ai_agent_id identities with lifecycle activity in the last 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(max by (connector, gen_ai_agent_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\"}[5m])) > time() - 300) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active agent_instance_id (5m, Loki)",
      "description": "Distinct defenseclaw.agent.instance_id values seen in canonical v8 log bodies during the last 5 minutes. The ID stays out of Prometheus labels to bound cardinality. A connector running multiple shells can show more than one instance.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(sum by (agent_instance_id) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | connector=~\"$connector\" | label_format agent_instance_id=\"{{.body_defenseclaw_agent_instance_id}}\" | agent_instance_id != \"\" [5m])))",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Sidecar instances (5m)",
      "description": "Distinct canonical correlation.sidecar_instance_id values seen in logs. This should be exactly one unless multiple sidecars share the host.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(sum by (sidecar_instance_id) (count_over_time({service_name=~\"defenseclaw|defenseclaw-audit\"} | json | __error__=\"\" | label_format sidecar_instance_id=\"{{.correlation_sidecar_instance_id}}\" | sidecar_instance_id != \"\" [5m])))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Discovery runs ($__range)",
      "description": "Exact canonical agent.discovery.completed and agent.discovery.rejected summary events recorded during the selected range. This log count includes a first report even when Prometheus has not yet scraped two counter samples.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | event_name=~\"agent[.]discovery[.](completed|rejected)\" [$__range])) or vector(0)",
          "refId": "A",
          "instant": true,
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "type": "stat",
      "title": "AI discovery active signals",
      "description": "Current active-signal count from the newest non-stale service instance per logical (source, privacy_mode). No data means no current discovery sample; 0 means the latest completed scan found no active signals.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(max by (source, privacy_mode) ((defenseclaw_ai_discovery_active_signals and (timestamp(defenseclaw_ai_discovery_active_signals) == on (source, privacy_mode) group_left max by (source, privacy_mode) (timestamp(defenseclaw_ai_discovery_active_signals)))) and (timestamp(defenseclaw_ai_discovery_active_signals) >= time() - 300)))",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Components observed",
      "description": "Distinct (ecosystem, name) components scored by the two-axis Bayesian engine.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(sum by (ecosystem, name) (last_over_time(defenseclaw_ai_components_installs[$__range])) > 0)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "title": "Per-connector activity (instability indicator)",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "text",
      "title": "How to read this row",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 24,
        "h": 2
      },
      "options": {
        "mode": "markdown",
        "content": "Identity health is a function of *traffic*. The two left panels populate as soon as any connector posts OTLP or fires a hook. The two right panels populate once an LLM call flows through the sidecar — they're sourced from Loki because `gen_ai.agent.id` is a log/event attribute (kept off Prometheus labels to bound cardinality)."
      }
    },
    {
      "type": "timeseries",
      "title": "OTLP records by connector (source)",
      "description": "Inbound OTLP-JSON records grouped by the `source` label (= connector name). Populates as soon as a connector starts posting to /v1/logs|metrics|traces. Empty == no connector wired to the local OTel collector yet.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (source) (rate(defenseclaw_otel_ingest_records_total{source=~\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "noValue": "no traffic"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Hook invocations by connector",
      "description": "Connector hook fires (`defenseclaw_connector_hook_invocations_total`) — `connector` label is the canonical name. Populates as soon as a hook script (Codex, Claude Code, Hermes, Cursor, Windsurf, GeminiCLI, Copilot) fires.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (connector) (rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[$__rate_interval]))",
          "legendFormat": "{{connector}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "noValue": "no hook traffic"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Distinct agent.id observed (Loki, by gen_ai.agent.name)",
      "description": "Loki-derived count of distinct `gen_ai_agent_id` values grouped by agent name for the selected connector. Populates only when canonical events carry agent identity.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "count by (agent_name) (sum by (agent_name, agent_id) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | connector=~\"$connector\" | label_format agent_name=\"{{.body_gen_ai_agent_name}}\", agent_id=\"{{.body_gen_ai_agent_id}}\" | agent_id != \"\" [$__interval])))",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "no LLM traffic yet"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Header-presence rate (Loki) — events with gen_ai.agent.id set",
      "description": "Loki-derived fraction of selected-connector canonical events that carry `gen_ai_agent_id`, grouped by agent name. 1.0 = all matching events retained an agent identity.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (agent_name) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | connector=~\"$connector\" | label_format agent_name=\"{{.body_gen_ai_agent_name}}\" | body_gen_ai_agent_id != \"\" [$__interval])) / sum by (agent_name) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | connector=~\"$connector\" | label_format agent_name=\"{{.body_gen_ai_agent_name}}\" [$__interval]))",
          "legendFormat": "{{agent_name}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "noValue": "no LLM traffic yet",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "On-demand agent discovery (CLI)",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "text",
      "title": "How to populate",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 2
      },
      "options": {
        "mode": "markdown",
        "content": "These panels track on-demand agent discovery runs (POST /agent/discovery). Run **`defenseclaw agent discover`** from any host with the CLI installed and reports will start landing here."
      }
    },
    {
      "type": "timeseries",
      "title": "Discovery runs by source × cache_hit × result",
      "description": "Per-minute rate of accepted on-demand discovery reports, broken down by report `source` (cli/api), whether the CLI hit its local cache, and the gateway's accept verdict (`ok`/`malformed`/`rejected`).",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (source, cache_hit, result) (rate(defenseclaw_agent_discovery_runs_total[$__rate_interval]))",
          "legendFormat": "{{source}} · cache={{cache_hit}} · {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "noValue": "no on-demand discoveries yet — run `defenseclaw agent discover`"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Discovery duration p50/p95",
      "description": "Wall-clock time per on-demand discovery scan, sourced from `defenseclaw_agent_discovery_duration_milliseconds`. Sustained p95 > 1s usually means a connector probe is timing out — cross-reference the errors table.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(defenseclaw_agent_discovery_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(defenseclaw_agent_discovery_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "noValue": "no on-demand discoveries yet"
        }
      }
    },
    {
      "type": "table",
      "title": "Per-connector install state (latest)",
      "description": "1=installed, 0=not installed. Sourced from `defenseclaw_agent_discovery_installed_ratio` (the gauge `defenseclaw.agent.discovery.installed` is unitless, so the OTel-Prometheus exporter appends the conventional `_ratio` suffix). Empty until at least one CLI discovery report lands.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "max by (connector) (last_over_time(defenseclaw_agent_discovery_installed_ratio{connector=~\"$connector\"}[$__range]))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "installed (latest)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "no on-demand discoveries yet"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "connector"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open Connector Detail",
                    "url": "/d/defenseclaw-connector-detail?${__url_time_range}&var-connector=${__value.text}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "installed (latest)"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "not installed",
                        "color": "red"
                      },
                      "1": {
                        "text": "installed",
                        "color": "green"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Discovery errors by connector × reason (1h)",
      "description": "Bounded error reasons emitted by `defenseclaw.agent.discovery.errors` (e.g. version-probe timeout, parse failure). Empty == clean discovery runs.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (connector, reason) (increase(defenseclaw_agent_discovery_errors_total{connector=~\"$connector\"}[1h]))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "errors/1h"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "no errors recorded"
        }
      }
    },
    {
      "type": "row",
      "title": "Continuous AI inventory (sidecar shadow-AI)",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "AI signals by category",
      "description": "Observed signals by the bounded continuous-discovery taxonomy. Per-sidecar cumulative counter maxima are summed across the selected range so a one-export discovery run is not undercounted.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (signal_category) (increase(defenseclaw_ai_discovery_signals_total[$__range]))",
          "legendFormat": "{{signal_category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "type": "table",
      "title": "Top vendors / products ($__range)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 42,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(20, sum by (ai_vendor, ai_product, signal_category) (increase(defenseclaw_ai_discovery_signals_total[$__range])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "signals/$__range"
            }
          }
        }
      ]
    },
    {
      "type": "histogram",
      "title": "Identity confidence distribution",
      "description": "Two-axis Bayesian engine identity_score [0,1] across all components. Cluster near 1.0 = strong identity (we're sure what this is). Cluster near 0 = ambiguous components — usually means the detector saw a signal that overlaps with multiple known products.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (le) (increase(defenseclaw_ai_confidence_identity_score_bucket[$__range]))",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "histogram",
      "title": "Presence confidence distribution",
      "description": "presence_score [0,1] — how confident the engine is that the component is currently installed. very_low presence with high identity is the 'SDK was removed but manifest still around' signature.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (le) (increase(defenseclaw_ai_confidence_presence_score_bucket[$__range]))",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Recent identity events (Loki)",
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "agent.discovery + ai.discovery events",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 59,
        "w": 24,
        "h": 14
      },
