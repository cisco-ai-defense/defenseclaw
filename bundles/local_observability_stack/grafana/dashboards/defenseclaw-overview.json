        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_invocations_total{connector=~\"$connector\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "links": [
            {
              "title": "Open Connectors dashboard",
              "url": "/d/defenseclaw-connectors?${__url_time_range}"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Exporter freshness",
      "description": "Seconds since the freshest configured exporter completed an export. The query intentionally has no deployment-specific job filter. Source family: metric.defenseclaw.telemetry.exporter.last_export_ts with the generated local-observability-v1 projection.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "time() - max(defenseclaw_telemetry_exporter_last_export_ts_seconds) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Top finding rule (range)",
      "description": "Scanner rule_id with the most canonical v8 findings in the selected time range.\n\ncovered_by:\n  - metric.defenseclaw.scan.findings.by_rule → internal/audit/scan_v8.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "topk(1, sum by (rule_id) (increase(defenseclaw_scan_findings_by_rule_total[$__range])))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "name"
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open Findings dashboard",
              "url": "/d/defenseclaw-findings?${__url_time_range}&var-severity=HIGH&var-severity=CRITICAL"
            }
          ]
        }
      }
    },
