        "y": 16,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "Hook latency SLO < 2.5s (5m)",
      "description": "Fraction of hook evaluations completing within 2.5s (nearest histogram bucket to 2s target).\n\ncovered_by:\n  - defenseclaw_connector_hook_latency_milliseconds → internal/gateway/hook_telemetry.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{le=\"2500\"}[5m])) / clamp_min(sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{le=\"+Inf\"}[5m])), 0.0001) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "title": "Active connectors (5m)",
      "description": "Distinct connectors that emitted hook invocations or OTLP records in the last 5 minutes. Click to open Connectors Overview.\n\ncovered_by:\n  - defenseclaw_connector_hook_invocations → internal/gateway/hook_telemetry.go\n  - defenseclaw_otel_ingest_records → internal/gateway/otel_ingest.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 17,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "count((sum by (connector) (rate(defenseclaw_connector_hook_invocations_total[5m])) > 0) or sum by (connector) (label_replace((sum by (source) (rate(defenseclaw_otel_ingest_records_total[5m])) > 0), \"connector\", \"$1\", \"source\", \"(.+)\"))) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Open Connectors dashboard",
