    {
      "type": "gauge",
      "title": "Hook latency SLO < 2.5s (5m)",
      "description": "Fraction of hook evaluations completing within 2.5s (nearest histogram bucket to 2s target).\n\ncovered_by:\n  - defenseclaw_connector_hook_latency_milliseconds → internal/gateway/hook_telemetry.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{le=\"2500.0\"}[5m])) / sum(rate(defenseclaw_connector_hook_latency_milliseconds_bucket{le=\"+Inf\"}[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
