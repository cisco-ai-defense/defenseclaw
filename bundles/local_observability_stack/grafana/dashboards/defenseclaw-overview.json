  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "description": "Optional connector filter. Sourced from defenseclaw_connector_hook_invocations_total{connector}. Applied to the guardrail-evaluation panels (which carry the tool=<connector>:<event> label) via tool=~\"$connector:.*\". Defaults to All (.+) so single-connector installs are unaffected; global panels (alerts, gateway/audit events, findings, errors) stay cross-connector.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
        "query": {
          "query": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "skipUrlSync": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Health KPIs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Firing alerts",
      "description": "Count of Prometheus alerting rules currently firing.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Verdicts / min",
      "description": "Guardrail verdicts emitted per minute across every stage.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations → internal/telemetry/metrics.go (RecordGuardrailEvaluation)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total{tool=~\"$connector:.*\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "type": "stat",
      "title": "Shadow blocks / min",
      "description": "Hook outcomes with would_block=true (observe mode). Real blocks use action=block in action mode.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          },
          "links": [
            {
              "title": "Open related dashboard",
              "url": "/d/defenseclaw-policy-decisions?${__url_time_range}"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Shadow block rate (5m)",
      "description": "Share of hook outcomes that would block in action mode.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[5m])) / clamp_min(sum(rate(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\"}[5m])), 0.0001) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          },
          "links": [
            {
              "title": "Open Policy decisions",
              "url": "/d/defenseclaw-policy-decisions?${__url_time_range}"
            }
          ]
        }
      }
    },
    {
      "type": "stat",
