    },
    {
      "type": "timeseries",
      "title": "Canonical events / sec by type",
      "description": "All canonical v8 log envelopes grouped by event_name. Source: generated log families under schemas/telemetry/v8, routed to Loki by the local-observability destination.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_name) (rate({service_name=\"defenseclaw\"} | json | __error__=\"\" [$__rate_interval]))",
          "legendFormat": "{{event_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Audit events / sec by action",
      "description": "Total audit records written by action type: claude-code-hook, otel.ingest.logs, otel.ingest.metrics.\n\ncovered_by:\n  - defenseclaw_audit_events → internal/audit (RecordAuditEvent)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_audit_events_total[$__rate_interval]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Guardrail evaluations",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Evaluations by action",
      "description": "Stacked guardrail decisions. A wedge of 'block' > 10% usually means a policy is too aggressive or the caller is probing.\n\ncovered_by:\n  - defenseclaw_inspect_evaluations → internal/gateway/hook_decision_metrics_v8.go; internal/gateway/inspect_metrics_v8.go\n  - defenseclaw_guardrail_evaluations → internal/gateway/proxy_guardrail_observability_v8.go; internal/gateway/api_guardrail_event_observability_v8.go; internal/gateway/api_guardrail_evaluate_observability_v8.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\"}[$__rate_interval]) or label_replace(rate(defenseclaw_guardrail_evaluations_total{guardrail_connector=~\"$connector\"}[$__rate_interval]), \"action\", \"$1\", \"guardrail_action_taken\", \"(.*)\"))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 20
          },
          "links": [
            {
              "title": "Open Security dashboard",
              "url": "/d/defenseclaw-security?${__url_time_range}&var-action=${__field.labels.action}"
            }
