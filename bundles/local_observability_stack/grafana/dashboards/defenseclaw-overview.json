{
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "enable": true,
        "expr": "ALERTS{alertstate=\"firing\"}",
        "iconColor": "red",
        "name": "Firing alerts",
        "tagKeys": "alertname,severity",
        "titleFormat": "{{alertname}} — {{severity}}",
        "useValueForTime": false
      }
    ]
  },
  "description": "Top-of-funnel landing for DefenseClaw hook connectors. KPI strip, SLOs, guardrail evaluations, findings, and Loki streams. HITL/OPA-specific panels use hook-mode equivalents where chat-HITL metrics are not emitted.",
