{
  "annotations": {
    "list": []
  },
  "description": "Guardrail policy decisions for hook connectors: inspect evaluations by action/severity, shadow blocks (would_block in observe mode), and internet egress inferred from tool commands. OPA/proxy-specific labels (policy_domain, policy_verdict) are not emitted in hook-only mode.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {
      "title": "Agent Activity (Live)",
      "type": "link",
      "url": "/d/defenseclaw-activity?${__url_time_range}&${connector:queryparam}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/defenseclaw-overview?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Verdicts",
      "type": "link",
      "url": "/d/defenseclaw-security?${__url_time_range}&var-stage=opa&var-stage=block_list&var-stage=multi_turn",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Findings",
      "type": "link",
      "url": "/d/defenseclaw-findings?${__url_time_range}",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "connector",
        "label": "Connector",
        "description": "Optional connector filter. Sourced from defenseclaw_connector_hook_invocations_total{connector}. Applied to the inspect/guardrail panels (block-list + multi-turn) which carry the tool=<connector>:<event> label via tool=~\"$connector:.*\". OPA and egress panels stay global (policy_evaluations/egress_events do not carry a connector label; egress 'source' is the go/ts tier, not a connector). Defaults to All (.+) so single-connector installs are unaffected.",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
        "query": {
          "query": "label_values(defenseclaw_connector_hook_invocations_total, connector)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "action",
        "label": "Verdict action",
        "description": "Filter guardrail evaluations by action (allow, block, warn, alert, confirm).",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "defenseclaw-prometheus"
        },
        "definition": "label_values(defenseclaw_inspect_evaluations_total, action)",
        "query": {
          "query": "label_values(defenseclaw_inspect_evaluations_total, action)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          }
        ],
        "skipUrlSync": false,
        "hide": 0
      },
      {
        "name": "egress_branch",
        "label": "Egress branch",
        "description": "Layer-1 shape detection branch. known = explicit destination match; shape = inferred by request shape; passthrough = no match.",
        "type": "custom",
        "query": "known,shape,passthrough",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ],
          "selected": true
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "known",
            "value": "known"
          },
          {
            "text": "shape",
            "value": "shape"
          },
          {
            "text": "passthrough",
            "value": "passthrough"
          }
        ],
        "skipUrlSync": false,
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Policy + egress KPIs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Guardrail evaluations / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\", action=~\"$action\"}[$__rate_interval])) * 60 or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          },
          "instant": true
        }
      ],
      "description": "Inspect pipeline evaluations per minute across selected connectors."
    },
    {
      "type": "stat",
      "title": "Block rate (range)",
      "description": "Fraction of guardrail evaluations with action=block.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_inspect_evaluations_total{connector=~\"$connector\", action=\"block\"}[$__range])) / clamp_min(sum(increase(defenseclaw_inspect_evaluations_total{connector=~\"$connector\", action=~\"$action\"}[$__range])), 0.0001) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "type": "stat",
      "title": "URL refs in commands (range)",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"defenseclaw\"} |~ \"https?://\" [$__range])) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          },
          "instant": true,
          "queryType": "instant"
        }
      ],
      "description": "Log lines containing http(s) URLs in tool commands. In local dev most refs are localhost (Grafana/Loki/Prometheus); external host panels filter those out."
    },
    {
      "type": "stat",
      "title": "Shadow block rate (observe)",
      "description": "would_block=true outcomes / all hook outcomes — policies that would block in action mode.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(increase(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[$__range])) / clamp_min(sum(increase(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\"}[$__range])), 0.0001) or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "type": "stat",
      "title": "Shadow blocks / min",
      "description": "Hook outcomes where would_block=true (observe-mode shadow blocks).",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[$__rate_interval])) * 60 or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          },
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "title": "Gateway errors / min",
      "description": "Gateway error events per minute.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_gateway_errors_total[$__rate_interval])) * 60 or vector(0)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          },
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "Guardrail verdicts",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Evaluations by tool × severity",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (tool, severity) (rate(defenseclaw_inspect_evaluations_total{connector=~\"$connector\", action=~\"$action\"}[$__rate_interval]))",
          "legendFormat": "{{tool}} · {{severity}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by connector",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, connector) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket{connector=~\"$connector\"}[$__rate_interval])))",
          "legendFormat": "{{connector}} p95",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Gateway events / sec by type",
      "description": "Spikes here while the system is otherwise stable mean the watcher is restarting OPA on noisy filesystem events.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(defenseclaw_gateway_events_emitted_total[$__rate_interval]))",
          "legendFormat": "{{event_type}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "table",
      "title": "Top URL hosts in commands (range)",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(10, sum by (host) (count_over_time({service_name=\"defenseclaw\"} |~ \"https?://\" | regexp \"https?://(?P<host>[a-zA-Z0-9._-]+)\" | host!=\"\" | host!~\"localhost|127\\\\..*\" [$__range])))",
          "instant": true,
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          },
          "queryType": "instant"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "denies/1h"
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Internet egress (from tool commands)",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "URL references by host (live)",
      "description": "branch ∈ {known, shape, passthrough}; decision ∈ {allow, block}. passthrough+allow indicates a destination DefenseClaw cannot classify — review for silent bypass.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (host) (count_over_time({service_name=\"defenseclaw\"} |~ \"https?://\" | regexp \"https?://(?P<host>[a-zA-Z0-9._-]+)\" | host!=\"\" [$__interval]))",
          "legendFormat": "{{host}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Shadow blocks / sec by connector",
      "description": "source ∈ {go, ts}: which tier of the gateway emitted the egress decision.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 23,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (connector) (rate(defenseclaw_connector_hook_outcome_total{connector=~\"$connector\", would_block=\"true\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "{{connector}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "defenseclaw-prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "row",
      "title": "Hook evaluation action and severity",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Evaluation actions over time",
      "description": "Hook evaluation outcomes by action. This metric does not carry a detector-stage label, so the panel intentionally makes no block-list or multi-turn attribution.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{tool=~\"$connector:.*\", action=~\"$action\"}[$__rate_interval]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 25
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Evaluations with classified severity",
      "description": "Hook evaluations with a non-NONE severity, grouped by action and severity. An allow action can still carry a classified severity; detector-stage attribution is available only where the emitted event carries it.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action, severity) (rate(defenseclaw_inspect_evaluations_total{severity!=\"NONE\", tool=~\"$connector:.*\"}[$__rate_interval]))",
          "legendFormat": "{{action}} · {{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "table",
      "title": "Top tools involved in evaluated actions (Loki, range)",
      "description": "Ranks tool-invocation events for the selected connector over the dashboard time range. Use the raw verdict stream for detector categories and decisions.",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(20, sum by (defenseclaw_tool_name) (count_over_time({service_name=\"defenseclaw\"} | gen_ai_agent_name=~\"$connector\" | defenseclaw_gateway_event_type=\"tool_invocation\" [$__range])))",
          "instant": true,
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Schema violations + recent OPA logs",
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Schema violations by event_type × code",
      "description": "Each (event_type, code) is a stable enum so no cardinality blow-up.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (error_subsystem, error_code) (rate(defenseclaw_gateway_errors_total[$__rate_interval])) or vector(0)",
          "legendFormat": "{{error_subsystem}} · {{error_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "type": "logs",
      "title": "Recent OPA + egress events",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 12,
        "y": 49,
        "w": 12,
        "h": 12
      },
      "timeFrom": "1h",
      "targets": [
        {
          "expr": "{service_name=\"defenseclaw\"} | gen_ai_agent_name=~\"$connector\" | defenseclaw_gateway_event_type=~\"tool_invocation|scan_finding|error\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": [
    "defenseclaw",
    "policy",
    "opa",
    "egress"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw — Policy decisions",
  "uid": "defenseclaw-policy-decisions",
  "version": 1,
  "weekStart": ""
}
