  "panels": [
    {
      "type": "row",
      "title": "HTTP surface",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "stat",
      "title": "Requests / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_http_request_count_total[5m])) or vector(0)",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "stat",
      "title": "5xx rate",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(rate(defenseclaw_http_request_count_total{http_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(defenseclaw_http_request_count_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "stat",
      "title": "Auth failures / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_gateway_errors_total[5m])) * 60 or vector(0)",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_auth_failures \u2192 internal/gateway/router.go\n\ncovered_by:\n  - defenseclaw_gateway_errors \u2192 internal/telemetry/gateway_events.go (EventError)"
    },
    {
      "type": "row",
      "title": "HTTP traffic",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Requests per route",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(defenseclaw_http_request_count_total[$__rate_interval]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "timeseries",
      "title": "Request duration p95 by route",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(defenseclaw_http_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_duration_milliseconds \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_duration_milliseconds \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "timeseries",
      "title": "Status code mix",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(defenseclaw_http_request_count_total[$__rate_interval]))",
          "legendFormat": "{{http_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_count \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
    {
      "type": "table",
      "title": "Top slow routes (p95, 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (le, http_route, http_method) (rate(defenseclaw_http_request_duration_milliseconds_bucket[5m]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "p95 ms"
            }
          }
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_duration_milliseconds \u2192 internal/gateway/router.go (otelhttp middleware)\n\ncovered_by:\n  - defenseclaw_http_request_duration_milliseconds \u2192 internal/gateway/router.go (otelhttp middleware)"
    },
