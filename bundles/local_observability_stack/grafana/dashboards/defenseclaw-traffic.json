  "panels": [
    {
      "type": "row",
      "title": "HTTP surface",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "stat",
      "title": "Requests / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_http_request_count_total[5m])) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_count → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "stat",
      "title": "5xx rate",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(rate(defenseclaw_http_request_count_total{http_status_code=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(defenseclaw_http_request_count_total[5m])), 0.0001)",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "stat",
      "title": "Auth failures / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(defenseclaw_http_auth_failures_total[5m])) * 60 or vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "description": "Authentication failures rejected by the sidecar, per minute.\n\ncovered_by:\n  - defenseclaw_http_auth_failures → internal/gateway/router.go"
    },
    {
      "type": "row",
      "title": "HTTP traffic",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Requests per route",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(defenseclaw_http_request_count_total[$__rate_interval]))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "timeseries",
      "title": "Request duration p95 by route",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(defenseclaw_http_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_duration_milliseconds → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "timeseries",
      "title": "Status code mix",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(defenseclaw_http_request_count_total[$__rate_interval]))",
          "legendFormat": "{{http_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "description": "covered_by:\n  - defenseclaw_http_request_count → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "table",
      "title": "Top slow routes (p95, 5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum by (le, http_route, http_method) (rate(defenseclaw_http_request_duration_milliseconds_bucket[5m]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service_namespace": true
            },
            "renameByName": {
              "Value": "p95 ms"
            }
          }
        }
      ],
      "description": "covered_by:\n  - defenseclaw_http_request_duration_milliseconds → internal/gateway/api_operational_metrics_v8.go (generated v8 middleware)"
    },
    {
      "type": "row",
      "title": "Tool calls + admission",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Tool invocations by tool",
      "datasource": {
        "type": "loki",
        "uid": "defenseclaw-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (tool_name) (count_over_time({service_name=\"defenseclaw\"} | json | __error__=\"\" | event_name=\"tool.invocation.completed\" | label_format tool_name=\"{{.body_gen_ai_tool_name}}\" [$__interval]))",
          "legendFormat": "{{defenseclaw_tool_name}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "defenseclaw-loki"
          }
        }
      ],
      "description": "covered_by:\n  - defenseclaw.gateway.tool_invocation Loki events"
    },
    {
      "type": "timeseries",
      "title": "Hook latency p95 by connector/event",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 40,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, connector, event_type) (rate(defenseclaw_connector_hook_latency_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{connector}} / {{event_type}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "description": "covered_by:\n  - defenseclaw_connector_hook_latency_milliseconds → internal/gateway/hook_telemetry.go"
    },
    {
      "type": "timeseries",
      "title": "Gateway errors by code",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (error_subsystem, error_code) (rate(defenseclaw_gateway_errors_total[$__rate_interval]))",
          "legendFormat": "{{error_subsystem}} / {{error_code}}",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_gateway_errors → internal/gateway/platform_health_observability_v8.go (generated structured failure metrics)"
    },
    {
      "type": "timeseries",
      "title": "Admission decisions",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 48,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total[$__rate_interval]) or label_replace(rate(defenseclaw_guardrail_evaluations_total[$__rate_interval]), \"action\", \"$1\", \"guardrail_action_taken\", \"(.*)\") or label_replace(rate(defenseclaw_admission_decisions_total[$__rate_interval]), \"action\", \"$1\", \"decision\", \"(.*)\"))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "description": "covered_by:\n  - defenseclaw_inspect_evaluations → internal/gateway/hook_decision_metrics_v8.go; internal/gateway/inspect_metrics_v8.go\n  - defenseclaw_guardrail_evaluations → internal/gateway/proxy_guardrail_observability_v8.go; internal/gateway/api_guardrail_event_observability_v8.go; internal/gateway/api_guardrail_evaluate_observability_v8.go\n  - defenseclaw_admission_decisions → internal/gateway/api_policy_observability_v8.go"
    },
    {
      "type": "row",
      "title": "Streaming responses",
      "gridPos": {
        "x": 0,
        "y": 69,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Stream transitions by outcome",
      "description": "SSE stream opens and terminal closes. Open uses outcome=attempted; close reports completed, blocked, failed, cancelled, or timed_out.\n\ncovered_by:\n  - defenseclaw_stream_lifecycle → internal/gateway/proxy_operational_metrics_v8.go",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 70,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (transition, outcome) (rate(defenseclaw_stream_lifecycle_total[$__rate_interval])) or on() vector(0)",
          "legendFormat": "{{transition}} · {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Stream duration by outcome",
      "description": "p50 and p95 completed or terminated SSE duration, measured through the final byte and correlated to the generated model span.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 70,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, outcome) (rate(defenseclaw_stream_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50 · {{outcome}}",
          "refId": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(defenseclaw_stream_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95 · {{outcome}}",
          "refId": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Stream bytes by outcome",
      "description": "p50 and p95 bytes written before stream close. Blocked streams include any bytes delivered before enforcement plus the terminal block frame.",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 70,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, outcome) (rate(defenseclaw_stream_bytes_sent_bucket[$__rate_interval])))",
          "legendFormat": "p50 · {{outcome}}",
          "refId": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(defenseclaw_stream_bytes_sent_bucket[$__rate_interval])))",
          "legendFormat": "p95 · {{outcome}}",
          "refId": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "type": "row",
      "title": "Guardrail evaluations",
      "gridPos": {
        "x": 0,
        "y": 56,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "stat",
      "title": "Non-allow evaluations / min",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "((sum(rate(defenseclaw_inspect_evaluations_total{action!~\"allow|none\"}[5m])) or vector(0)) + (sum(rate(defenseclaw_guardrail_evaluations_total{guardrail_action_taken!~\"allow|none\"}[5m])) or vector(0))) * 60",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "description": "covered_by:\n  - defenseclaw_inspect_evaluations → internal/gateway/hook_decision_metrics_v8.go; internal/gateway/inspect_metrics_v8.go\n  - defenseclaw_guardrail_evaluations → internal/gateway/proxy_guardrail_observability_v8.go; internal/gateway/api_guardrail_event_observability_v8.go; internal/gateway/api_guardrail_evaluate_observability_v8.go"
    },
    {
      "type": "timeseries",
      "title": "Guardrail latency p50/p95/p99",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 61,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval]) or rate(defenseclaw_guardrail_latency_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval]) or rate(defenseclaw_guardrail_latency_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(defenseclaw_inspect_latency_milliseconds_bucket[$__rate_interval]) or rate(defenseclaw_guardrail_latency_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "description": "covered_by:\n  - defenseclaw_inspect_latency_milliseconds → internal/gateway/hook_decision_metrics_v8.go; internal/gateway/inspect_metrics_v8.go\n  - defenseclaw_guardrail_latency_milliseconds → internal/gateway/proxy_guardrail_observability_v8.go; internal/gateway/api_guardrail_event_observability_v8.go; internal/gateway/api_guardrail_evaluate_observability_v8.go"
    },
    {
      "type": "timeseries",
      "title": "Non-allow evaluations by action",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 61,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (action) (rate(defenseclaw_inspect_evaluations_total{action!~\"allow|none\"}[$__rate_interval]) or label_replace(rate(defenseclaw_guardrail_evaluations_total{guardrail_action_taken!~\"allow|none\"}[$__rate_interval]), \"action\", \"$1\", \"guardrail_action_taken\", \"(.*)\")) or on() vector(0)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "description": "covered_by:\n  - defenseclaw_inspect_evaluations → internal/gateway/hook_decision_metrics_v8.go; internal/gateway/inspect_metrics_v8.go\n  - defenseclaw_guardrail_evaluations → internal/gateway/proxy_guardrail_observability_v8.go; internal/gateway/api_guardrail_event_observability_v8.go; internal/gateway/api_guardrail_evaluate_observability_v8.go"
    },
    {
      "type": "row",
      "title": "GenAI tokens + LLM duration (proxy)",
      "gridPos": {
        "x": 0,
        "y": 103,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "timeseries",
      "title": "Tokens / sec by direction x model",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 104,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type, gen_ai_request_model) ((((increase(gen_ai_client_token_usage_sum[$__rate_interval]) or (last_over_time(gen_ai_client_token_usage_sum[$__rate_interval]) * 0)) and gen_ai_client_token_usage_sum offset $__rate_interval) or (last_over_time(gen_ai_client_token_usage_sum[$__rate_interval]) unless gen_ai_client_token_usage_sum offset $__rate_interval))) / ($__rate_interval_ms / 1000)",
          "legendFormat": "{{gen_ai_request_model}} {{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "suffix: tokens/sec"
        }
      },
      "description": "Window-average reported token rate by model and direction. Established series use counter delta divided by the window; a series first published inside the window uses its latest cumulative completion value divided by the window. It is not an instantaneous rate; absent series mean token usage was not reported.\n\ncovered_by:\n  - gen_ai_client_token_usage → generated OTel GenAI v8 metrics via internal/gateway/proxy_observability_v8.go and internal/gateway/hook_lifecycle_metrics_v8.go"
    },
    {
      "type": "timeseries",
      "title": "LLM op duration (p50/p95/p99)",
      "datasource": {
        "type": "prometheus",
        "uid": "defenseclaw-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 104,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "description": "covered_by:\n  - gen_ai_client_operation_duration_seconds → generated OTel GenAI v8 metrics via internal/gateway/proxy_observability_v8.go and internal/gateway/hook_lifecycle_metrics_v8.go"
    },
    {
      "type": "row",
      "title": "Traces (Tempo)",
      "gridPos": {
        "x": 0,
        "y": 112,
        "w": 24,
        "h": 1
      }
    },
    {
      "type": "table",
      "title": "Recent gateway traces",
      "description": "TraceQL search for the defenseclaw service. Click the trace ID cell to open the flame graph in Explore.",
      "datasource": {
        "type": "tempo",
        "uid": "defenseclaw-tempo"
      },
      "gridPos": {
        "x": 0,
        "y": 113,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
