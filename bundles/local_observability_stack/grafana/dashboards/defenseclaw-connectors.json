{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "links": [
    {"title": "Overview",  "type": "link", "url": "/d/defenseclaw-overview",  "icon": "external link", "targetBlank": false},
    {"title": "Security",  "type": "link", "url": "/d/defenseclaw-security",  "icon": "external link", "targetBlank": false},
    {"title": "Reliability","type": "link", "url": "/d/defenseclaw-reliability", "icon": "external link", "targetBlank": false}
  ],
  "panels": [
    {"type": "row", "title": "Connector telemetry summary", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "stat",
      "title": "Total OTLP requests / min",
      "description": "Across all connectors and signals. Sum of /v1/logs + /v1/metrics + /v1/traces requests in the last 5 minutes, scaled to per-minute. A flat-line at zero on a host where codex/claudecode is supposed to be running observability mode means the gateway is not receiving telemetry.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_otel_ingest_requests_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "OTel records / min",
      "description": "Leaf records (logRecords + dataPoints + spans) extracted from inbound batches. Drives the per-connector volume time series below.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 4, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_otel_ingest_records_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Codex turns / min",
      "description": "agent-turn-complete + other notify events posted by codex's notify-bridge.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 8, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_codex_notify_total[5m])) * 60 or vector(0)", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Malformed-payload rate",
      "description": "Fraction of inbound OTLP-HTTP bodies the receiver rejected for failed JSON parsing. >10% triggers DefenseClawConnectorTelemetryMalformed.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(defenseclaw_otel_ingest_malformed_total[5m])) / clamp_min(sum(rate(defenseclaw_otel_ingest_requests_total[5m])), 0.0001) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.05}, {"color": "red", "value": 0.10}]}}}
    },
    {
      "type": "stat",
      "title": "Loudest source",
      "description": "Connector source emitting the most OTel log records. Helps spot a runaway codex or claudecode session.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 16, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "topk(1, sum by (source) (rate(defenseclaw_otel_ingest_records_total{signal=\"logs\"}[5m])))", "refId": "A", "instant": true}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "/^source$/"}, "colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "type": "stat",
      "title": "Quietest source (silence sec)",
      "description": "Maximum seconds since the gateway received an OTel batch from any connector. >600s triggers DefenseClawConnectorTelemetrySilent.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 20, "y": 1, "w": 4, "h": 4},
      "targets": [{"expr": "max(connector:defenseclaw_otel_ingest_silence:seconds) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 60}, {"color": "red", "value": 600}]}}}
    },

    {"type": "row", "title": "OTLP ingest by connector", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Requests per second by source / signal",
      "description": "Rate of OTLP-HTTP batches accepted, broken out by connector source and signal type. Drift between codex and claudecode rates is expected (claudecode emits logs+metrics; codex emits logs+metrics+traces).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (source, signal) (rate(defenseclaw_otel_ingest_requests_total[$__rate_interval]))", "legendFormat": "{{source}} · {{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "Records per second (volume) by source / signal",
      "description": "Leaf records (logRecords / data points / spans) per second. Use this rather than request rate to compare connector verbosity since one batch can carry hundreds of records.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (source, signal) (rate(defenseclaw_otel_ingest_records_total[$__rate_interval]))", "legendFormat": "{{source}} · {{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "Bytes per second by source / signal",
      "description": "Inbound body size. Spikes correlate with verbose tool-use prompts or large completions.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (source, signal) (rate(defenseclaw_otel_ingest_bytes_total[$__rate_interval]))", "legendFormat": "{{source}} · {{signal}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "table",
      "title": "Per-source ingest mix",
      "description": "Last-5m rate per (source, signal, result). Lets you eyeball which connectors are emitting which signals and whether any are throwing malformed.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
      "targets": [{"expr": "sort_desc(sum by (source, signal, result) (rate(defenseclaw_otel_ingest_requests_total[5m])) * 60)", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true}, "renameByName": {"Value": "req/min"}}}]
    },

    {"type": "row", "title": "Codex notify (turn-complete)", "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Notify events per second by type / result",
      "description": "Codex notify-bridge events. Result=malformed in this panel means the bridge sent a body that didn't parse as JSON — investigate codex schema drift.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (type, result) (rate(defenseclaw_codex_notify_total[$__rate_interval]))", "legendFormat": "{{type}} · {{result}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "table",
      "title": "Notify events by type + status",
      "description": "Last-5m totals by codex's `type` and `status` fields. status=success vs status=failed lets you spot turns the model gave up on.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "targets": [{"expr": "sort_desc(sum by (type, status, result) (increase(defenseclaw_codex_notify_total[5m])))", "instant": true, "format": "table", "refId": "A"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "job": true, "instance": true, "service_namespace": true}, "renameByName": {"Value": "events/5m"}}}]
    },

    {"type": "row", "title": "Hooks vs OTel logs (drift detection)", "gridPos": {"x": 0, "y": 31, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Hook-emitted audit events / sec",
      "description": "Audit rows for tool-call / tool-result / codex.notify.* — this is the hook channel of the observability story. A persistent positive value here with zero on the OTel logs panel below means OTel export is broken (token? CSRF? firewall?).",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 8},
      "targets": [{"expr": "connector:defenseclaw_hooks:rate5m", "legendFormat": "{{action}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "OTel log records / sec by source",
      "description": "Inbound /v1/logs records. Compare with the hook panel to spot drift.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 8},
      "targets": [{"expr": "connector:defenseclaw_otel_logs:rate5m", "legendFormat": "{{source}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },

    {"type": "row", "title": "GenAI tokens (per connector)", "gridPos": {"x": 0, "y": 40, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "timeseries",
      "title": "Tokens / sec by service.name + direction",
      "description": "OTel GenAI semconv counter (gen_ai.client.token.usage). Claude Code emits these natively when CLAUDE_CODE_ENABLE_TELEMETRY=1; codex emits them when [otel] is configured. Filter by service.name to see codex vs claudecode separately.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 0, "y": 41, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (service_name, gen_ai_token_type) (rate(gen_ai_client_token_usage_tokens_sum[$__rate_interval]))", "legendFormat": "{{service_name}} · {{gen_ai_token_type}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "type": "timeseries",
      "title": "LLM operation duration p95 by service",
      "description": "OTel GenAI gen_ai.client.operation.duration. p95 stays under your model's typical response time when the service is healthy.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"},
      "gridPos": {"x": 12, "y": 41, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(gen_ai_client_operation_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{service_name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },

    {"type": "row", "title": "Recent connector events (Loki)", "gridPos": {"x": 0, "y": 49, "w": 24, "h": 1}, "collapsed": false},

    {
      "type": "logs",
      "title": "Connector telemetry log stream",
      "description": "OTel log records emitted by the gateway when it accepts an OTLP batch or codex notify. Search by event.name=defenseclaw.otel.ingest or event.name=defenseclaw.codex.notify, then by source to filter to one connector.",
      "datasource": {"type": "loki", "uid": "defenseclaw-loki"},
      "gridPos": {"x": 0, "y": 50, "w": 24, "h": 12},
      "targets": [{"expr": "{service_namespace=\"defenseclaw\"} | json | event_name=~\"defenseclaw\\\\.(otel\\\\.ingest|codex\\\\.notify)\"", "refId": "A"}],
      "options": {"showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["defenseclaw", "observability", "connectors", "codex", "claudecode"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "DefenseClaw — Connectors",
  "uid": "defenseclaw-connectors",
  "version": 1,
  "weekStart": ""
}
