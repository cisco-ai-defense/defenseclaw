      "targets": [{"expr": "100 * sum(last_over_time(defenseclaw_agent_lifecycle_transitions_total{connector=~\"$connector\",$scope_label=~\"$agent\",defenseclaw_agent_lifecycle_state=\"completed\"}[$__range])) / clamp_min(sum(last_over_time(defenseclaw_agent_lifecycle_transitions_total{connector=~\"$connector\",$scope_label=~\"$agent\",defenseclaw_agent_lifecycle_state=~\"completed|failed|interrupted\"}[$__range])), 1)", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 95}]}}, "overrides": []}, "options": {"showThresholdLabels": false, "showThresholdMarkers": true}
    },
