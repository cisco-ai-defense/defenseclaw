{
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "-- Grafana --"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "description": "Dynamic drill-down for every automatically observed DefenseClaw agent. Stable agent/root/parent/lifecycle/execution IDs correlate Prometheus inventory and totals, Loki event detail, and Tempo traces.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Agent Directory", "type": "link", "url": "/d/defenseclaw-agent-identity/agent-identity"},
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Activity", "type": "link", "url": "/d/defenseclaw-activity/activity"}
  ],
  "liveNow": true,
  "panels": [
    {
      "id": 1, "type": "text", "title": "Agent360", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 3},
      "options": {"mode": "markdown", "content": "# Agent360 · `$agent`\nStable identity → lifecycle/executions → models, tools, websites, security decisions → Tempo trace. **Scope** chooses only this agent or its full descendant tree. Unknown tokens/cost remain absent rather than being rendered as zero."}
    },
    {
      "id": 2, "type": "table", "title": "Agent Directory — click an Agent ID to drill down", "description": "Every hook lifecycle transition updates defenseclaw.agent.last_seen. This table therefore discovers new agents automatically; no dashboard JSON is generated per agent.",
      "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 3, "w": 24, "h": 8},
      "targets": [{"expr": "1000 * topk by (gen_ai_agent_id) (1, max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\"}[$__range]))", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [{"id": "labelsToFields", "options": {"mode": "columns"}}, {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true, "defenseclaw_agent_execution_id": true, "defenseclaw_agent_lifecycle_event": true, "defenseclaw_agent_lifecycle_id": true, "defenseclaw_agent_lifecycle_state": true, "defenseclaw_agent_depth": true, "gen_ai_provider_name": true, "gen_ai_request_model": true, "defenseclaw_claw_mode": true, "defenseclaw_device_id": true, "defenseclaw_gateway_host": true, "defenseclaw_gateway_port": true, "defenseclaw_instance_id": true, "defenseclaw_session_root_id": true, "deployment_environment": true, "host_arch": true, "host_name": true, "instance": true, "job": true, "os_type": true, "service": true, "service_name": true, "service_namespace": true, "service_version": true, "exported_job": true}, "renameByName": {"Value": "Last Seen", "connector": "Connector", "gen_ai_agent_id": "Agent ID", "gen_ai_agent_name": "Name", "gen_ai_agent_type": "Type", "defenseclaw_agent_root_id": "Root Agent", "defenseclaw_agent_parent_id": "Parent Agent"}}}],
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}}, "overrides": [{"matcher": {"id": "byName", "options": "Agent ID"}, "properties": [{"id": "links", "value": [{"title": "Open Agent360", "url": "/d/defenseclaw-agent-360/agent360?var-connector=${__data.fields.Connector}&var-agent=${__data.fields[\"Root Agent\"]}&var-scope_label=defenseclaw_agent_root_id", "targetBlank": false}]}]}, {"matcher": {"id": "byName", "options": "Last Seen"}, "properties": [{"id": "unit", "value": "dateTimeFromNow"}]}]},
      "options": {"showHeader": true, "cellHeight": "sm", "sortBy": [{"displayName": "Last Seen", "desc": true}]}
    },
    {
      "id": 3, "type": "stat", "title": "Last seen", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 11, "w": 3, "h": 4},
      "targets": [{"expr": "time() - max(max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range]))", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 300}, {"color": "red", "value": 1800}]}}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "none", "textMode": "value"}
    },
    {
      "id": 4, "type": "stat", "title": "Turns", "description": "Completed turns counted from the durable lifecycle event stream, so collector restarts and sparse counter samples do not erase the total.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 3, "y": 11, "w": 2, "h": 4},
      "targets": [{"expr": "sum(count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"lifecycle\" | json | connector=~\"$connector\" | agent_lifecycle_event=\"turn_end\" [$__range])) or vector(0)", "instant": true, "queryType": "instant", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 26, "type": "stat", "title": "Model calls", "description": "Model responses counted from the durable LLM event stream. This includes intermediate responses that do not close the overall agent turn.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 5, "y": 11, "w": 2, "h": 4},
      "targets": [{"expr": "sum(count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"llm_response\" | json | connector=~\"$connector\" [$__range])) or vector(0)", "instant": true, "queryType": "instant", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 5, "type": "stat", "title": "Tool calls", "description": "Completed tool results counted from the durable tool event stream. Post-only hook connectors remain visible even when no matching pre-hook was observed.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 7, "y": 11, "w": 2, "h": 4},
      "targets": [{"expr": "sum(count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"tool_invocation\" | json | connector=~\"$connector\" | tool_invocation_phase=\"result\" [$__range])) or vector(0)", "instant": true, "queryType": "instant", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 6, "type": "stat", "title": "Descendants", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 9, "y": 11, "w": 2, "h": 4},
      "targets": [{"expr": "count(count by (gen_ai_agent_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",defenseclaw_agent_root_id=~\"$agent\",gen_ai_agent_id!=\"$agent\"}[$__range]))) or vector(0)", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 7, "type": "stat", "title": "Input tokens", "description": "Connector-reported prompt/context tokens from completed model calls. Long-context agents can report much more input than output. Missing usage is absent, not guessed.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 11, "y": 11, "w": 3, "h": 4},
      "targets": [{"expr": "sum(increase(defenseclaw_agent_token_usage_total{connector=~\"$connector\",$scope_label=~\"$agent\",kind=\"input\"}[$__range]))", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "noValue": "Not reported"}, "overrides": []}, "options": {"colorMode": "none", "graphMode": "none"}
    },
    {
      "id": 8, "type": "stat", "title": "Output tokens", "description": "Connector-reported completion tokens from completed model calls. Missing usage is absent, not guessed.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 14, "y": 11, "w": 3, "h": 4},
      "targets": [{"expr": "sum(increase(defenseclaw_agent_token_usage_total{connector=~\"$connector\",$scope_label=~\"$agent\",kind=\"output\"}[$__range]))", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "noValue": "Not reported"}, "overrides": []}, "options": {"colorMode": "none", "graphMode": "none"}
    },
    {
      "id": 9, "type": "stat", "title": "Reported cost", "description": "Latest cumulative USD cost only when the connector explicitly reports it. DefenseClaw does not estimate prices.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 17, "y": 11, "w": 3, "h": 4},
      "targets": [{"expr": "sum(max by (gen_ai_agent_id, defenseclaw_agent_lifecycle_id) (max_over_time(defenseclaw_agent_reported_cost_USD{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])))", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "noValue": "Not reported"}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 10, "type": "gauge", "title": "Terminal success", "description": "Completed terminal lifecycle events divided by completed, failed, and interrupted terminal events in Loki. Active-only ranges correctly remain without a terminal outcome.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 20, "y": 11, "w": 4, "h": 4},
      "targets": [{"expr": "100 * sum(count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"lifecycle\" | json | connector=~\"$connector\" | agent_lifecycle_state=\"completed\" [$__range])) / sum(count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"lifecycle\" | json | connector=~\"$connector\" | agent_lifecycle_state=~\"completed|failed|interrupted\" [$__range]))", "instant": true, "queryType": "instant", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "percent", "noValue": "No terminal outcome", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 80}, {"color": "green", "value": 95}]}}, "overrides": []}, "options": {"showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {"id": 11, "type": "row", "title": "Lifecycle, throughput, latency, and tokens", "gridPos": {"x": 0, "y": 15, "w": 24, "h": 1}, "collapsed": false},
    {
      "id": 12, "type": "state-timeline", "title": "Execution phase timeline", "description": "Continuous per-execution state from the native phase gauge. Values persist between scrapes, while the ordered sequence below retains every sub-scrape transition.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [{"expr": "max by (gen_ai_agent_name, defenseclaw_agent_execution_id) (defenseclaw_agent_phase_current_ratio{connector=~\"$connector\",$scope_label=~\"$agent\",defenseclaw_agent_execution_id=~\"$execution\"})", "legendFormat": "{{gen_ai_agent_name}} · {{defenseclaw_agent_execution_id}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "Unknown", "color": "gray"}, "1": {"text": "Session", "color": "blue"}, "2": {"text": "Planning", "color": "purple"}, "3": {"text": "Model", "color": "yellow"}, "4": {"text": "Tool", "color": "orange"}, "5": {"text": "Approval", "color": "dark-orange"}, "6": {"text": "Waiting", "color": "light-blue"}, "7": {"text": "Responding", "color": "green"}, "8": {"text": "Maintenance", "color": "dark-blue"}, "9": {"text": "Completed", "color": "semi-dark-green"}, "10": {"text": "Failed", "color": "red"}, "11": {"text": "Interrupted", "color": "dark-red"}, "12": {"text": "Observed", "color": "gray"}}}], "custom": {"fillOpacity": 80, "lineWidth": 0, "spanNulls": true}}, "overrides": []}, "options": {"alignValue": "left", "mergeValues": true, "rowHeight": 0.8, "showValue": "auto", "tooltip": {"mode": "single", "sort": "none"}}
    },
    {
      "id": 13, "type": "timeseries", "title": "Agent span throughput", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 12, "y": 16, "w": 6, "h": 8},
      "targets": [{"expr": "sum by (span_name) ((rate(defenseclaw_agent_span_calls_total{$scope_label=~\"$agent\"}[$__rate_interval])) and on (defenseclaw_agent_execution_id) (max by (defenseclaw_agent_execution_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])) >= (time() - $__range_s)))", "legendFormat": "{{span_name}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 14, "type": "timeseries", "title": "Agent span p95 latency", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 18, "y": 16, "w": 6, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, span_name) ((rate(defenseclaw_agent_span_duration_milliseconds_bucket{$scope_label=~\"$agent\"}[$__rate_interval])) and on (defenseclaw_agent_execution_id) (max by (defenseclaw_agent_execution_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])) >= (time() - $__range_s))))", "legendFormat": "{{span_name}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ms", "custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 2}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 15, "type": "timeseries", "title": "Input/output tokens over time", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [{"expr": "sum by (kind) (rate(defenseclaw_agent_token_usage_total{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__rate_interval]))", "legendFormat": "{{kind}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "tps", "custom": {"drawStyle": "bars", "fillOpacity": 35}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 16, "type": "table", "title": "Executions and last activity", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [{"expr": "1000 * max by (gen_ai_agent_id, defenseclaw_agent_lifecycle_id, defenseclaw_agent_execution_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\",defenseclaw_agent_lifecycle_id=~\"$lifecycle\",defenseclaw_agent_execution_id=~\"$execution\"}[$__range]))", "format": "table", "instant": true, "refId": "A"}],
      "transformations": [{"id": "labelsToFields", "options": {"mode": "columns"}}, {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true}, "renameByName": {"Value": "Last Seen", "gen_ai_agent_id": "Agent", "defenseclaw_agent_lifecycle_id": "Lifecycle", "defenseclaw_agent_execution_id": "Execution"}}}], "fieldConfig": {"defaults": {}, "overrides": [{"matcher": {"id": "byName", "options": "Last Seen"}, "properties": [{"id": "unit", "value": "dateTimeFromNow"}]}]}, "options": {"showHeader": true, "cellHeight": "sm"}
    },
    {"id": 27, "type": "row", "title": "Model, tool, cost, lifecycle, and reliability analytics", "gridPos": {"x": 0, "y": 32, "w": 24, "h": 1}, "collapsed": false},
    {
      "id": 28, "type": "bargauge", "title": "Model calls by provider and model", "description": "Durable LLM response events grouped by the provider/model actually reported by the connector. Missing model identity is shown as unreported rather than guessed.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 0, "y": 33, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (provider, model) (count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"llm_response\" | json | connector=~\"$connector\" | label_format model=\"{{if .model}}{{.model}}{{else}}unreported{{end}}\" [$__range]))", "queryType": "instant", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "legendFormat": "{{provider}} / {{model}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "values": false}, "showUnfilled": true}
    },
    {
      "id": 29, "type": "bargauge", "title": "Execution-lifetime model p95 (active in range)", "description": "Cumulative p95 for executions with activity in the selected range. Execution-scoped histogram state keeps sparse and single-call agents visible without mixing in inactive executions.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 8, "y": 33, "w": 8, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, gen_ai_provider_name, gen_ai_request_model) ((last_over_time(defenseclaw_agent_span_duration_milliseconds_bucket{$scope_label=~\"$agent\",gen_ai_request_model!=\"\",gen_ai_operation_name=~\"chat|generate_content|text_completion\"}[$__range])) and on (defenseclaw_agent_execution_id) (max by (defenseclaw_agent_execution_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])) >= (time() - $__range_s))))", "instant": true, "legendFormat": "{{gen_ai_provider_name}} / {{gen_ai_request_model}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 30, "type": "bargauge", "title": "Top tools by calls", "description": "Exact result-event counts in the selected time range; duplicate counter state from older executions is excluded.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 16, "y": 33, "w": 8, "h": 8},
      "targets": [{"expr": "topk(10, sum by (tool_name) (count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=\"tool_invocation\" | json | connector=~\"$connector\" | tool_invocation_phase=\"result\" | tool_name!=\"\" [$__range])))", "instant": true, "queryType": "instant", "legendFormat": "{{tool_name}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 31, "type": "bargauge", "title": "Execution-lifetime tool p95 (active in range)", "description": "Cumulative p95 for tool executions with activity in the selected range. Execution-scoped histogram state keeps one-off tools visible.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 41, "w": 8, "h": 8},
      "targets": [{"expr": "topk(10, histogram_quantile(0.95, sum by (le, gen_ai_tool_name) ((last_over_time(defenseclaw_agent_span_duration_milliseconds_bucket{$scope_label=~\"$agent\",gen_ai_tool_name!=\"\"}[$__range])) and on (defenseclaw_agent_execution_id) (max by (defenseclaw_agent_execution_id) (max_over_time(defenseclaw_agent_last_seen_seconds{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])) >= (time() - $__range_s)))))", "instant": true, "legendFormat": "{{gen_ai_tool_name}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "ms"}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 32, "type": "bargauge", "title": "Top websites and destinations", "description": "Destination applications inferred from tool and network spans; raw host detail remains in Loki.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 8, "y": 41, "w": 8, "h": 8},
      "targets": [{"expr": "topk(10, sum by (destination) (count_over_time({service_name=\"defenseclaw\"} | $scope_label=~\"$agent\" | defenseclaw_gateway_event_type=~\"tool_invocation|egress\" | json | connector=~\"$connector\" | label_format destination=\"{{if .destination_app}}{{.destination_app}}{{else}}{{.destination_host}}{{end}}\" | destination!=\"\" [$__range])))", "instant": true, "queryType": "instant", "legendFormat": "{{destination}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 39, "type": "bargauge", "title": "Reported tokens by model", "description": "Only connector-reported token usage. New observations carry provider/model labels; missing usage is not estimated.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 16, "y": 41, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (gen_ai_provider_name, gen_ai_request_model, kind) (increase(defenseclaw_agent_token_usage_total{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range]))", "instant": true, "legendFormat": "{{gen_ai_provider_name}} / {{gen_ai_request_model}} / {{kind}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 33, "type": "timeseries", "title": "Reported cost over time", "description": "Latest cumulative connector-reported USD total per lifecycle; no price-table estimate is introduced.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 0, "y": 49, "w": 8, "h": 8},
      "targets": [{"expr": "sum(max by (gen_ai_agent_id, defenseclaw_agent_lifecycle_id, gen_ai_provider_name, gen_ai_request_model) (defenseclaw_agent_reported_cost_USD{connector=~\"$connector\",$scope_label=~\"$agent\"}))", "legendFormat": "reported USD", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4, "custom": {"drawStyle": "line", "fillOpacity": 20}}, "overrides": []}, "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 34, "type": "bargauge", "title": "Reported cost by model", "description": "Cumulative reported cost grouped by the model/provider carried by the lifecycle observation.", "datasource": {"type": "prometheus", "uid": "defenseclaw-prometheus"}, "gridPos": {"x": 8, "y": 49, "w": 8, "h": 8},
      "targets": [{"expr": "sum by (gen_ai_provider_name, gen_ai_request_model) (max by (gen_ai_agent_id, defenseclaw_agent_lifecycle_id, gen_ai_provider_name, gen_ai_request_model) (max_over_time(defenseclaw_agent_reported_cost_USD{connector=~\"$connector\",$scope_label=~\"$agent\"}[$__range])))", "instant": true, "legendFormat": "{{gen_ai_provider_name}} / {{gen_ai_request_model}}", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 4}, "overrides": []}, "options": {"displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true}
    },
    {
      "id": 35, "type": "table", "title": "Lifecycle funnel", "description": "Exact lifecycle event totals from Loki. This remains accurate across collector restarts and includes sparse pre/post hook transitions.", "datasource": {"type": "loki", "uid": "defenseclaw-loki"}, "gridPos": {"x": 16, "y": 49, "w": 8, "h": 8},
