      "targets": [{"expr": "sum(last_over_time(defenseclaw_agent_lifecycle_transitions_total{connector=~\"$connector\",$scope_label=~\"$agent\",defenseclaw_agent_lifecycle_event=\"tool_start\"}[$__range])) or vector(0)", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area"}
