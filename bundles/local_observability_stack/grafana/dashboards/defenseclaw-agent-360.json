      "targets": [{"expr": "sum(last_over_time(defenseclaw_agent_token_usage_total{connector=~\"$connector\",$scope_label=~\"$agent\",kind=\"output\"}[$__range]))", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "noValue": "Not reported"}, "overrides": []}, "options": {"colorMode": "none", "graphMode": "none"}
