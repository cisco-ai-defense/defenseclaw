      "targets": [{"expr": "sum(last_over_time(defenseclaw_agent_span_calls_total{$scope_label=~\"$agent\",gen_ai_operation_name=~\"chat|generate_content|text_completion\"}[$__range])) or vector(0)", "instant": true, "refId": "A"}], "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []}, "options": {"colorMode": "value", "graphMode": "area"}
