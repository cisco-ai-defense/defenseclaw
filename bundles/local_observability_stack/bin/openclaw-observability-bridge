#!/usr/bin/env sh
# Backward-compatible POSIX entry point. The lifecycle implementation is the
# same packaged Python controller used by the DefenseClaw CLI on every OS.
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
CONTROLLER_BIN=${DEFENSECLAW_OBSERVABILITY_BIN:-defenseclaw-observability}
exec "$CONTROLLER_BIN" --stack-dir "$ROOT_DIR" "$@"
