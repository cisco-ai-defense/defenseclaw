{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Mandatory AXIS execution request","type":"object","additionalProperties":false,"required":["protocol_version","execution_id","mcp_session_id","tool_call_id","tool_class","workspace","relative_cwd","invocation","request_digest"],"properties":{"protocol_version":{"const":"axis-execution/v1"},"execution_id":{"type":"string","minLength":1,"maxLength":128},"mcp_session_id":{"type":"string","minLength":1,"maxLength":128},"tool_call_id":{"type":"string","minLength":1,"maxLength":128},"tool_class":{"enum":["read","write","patch"]},"workspace":{"type":"string","pattern":"^/home/cisco/workspaces/"},"relative_cwd":{"type":"string","maxLength":512,"pattern":"^[^/].*$"},"invocation":{"type":"object","additionalProperties":false,"required":["program"],"properties":{"program":{"type":"string","minLength":1,"maxLength":256},"args":{"type":"array","maxItems":128,"items":{"type":"string","maxLength":4096}},"stdin_hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},"patch_hash":{"type":"string","pattern":"^[a-f0-9]{64}$"},"timeout_seconds":{"type":"integer","minimum":0,"maximum":900}}},"request_digest":{"type":"string","pattern":"^[a-f0-9]{64}$"}}}