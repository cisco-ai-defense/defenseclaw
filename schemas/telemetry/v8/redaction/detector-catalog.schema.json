{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defenseclaw.dev/schemas/telemetry/v8/redaction/detector-catalog.schema.json",
  "title": "DefenseClaw observability redaction detector catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["catalog_version", "groups", "detectors"],
  "properties": {
    "catalog_version": {"const": 1},
    "groups": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["token", "detector_ids"],
        "properties": {
          "token": {"enum": ["credentials", "secrets", "pii"]},
          "detector_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(credentials|secrets|pii)\\.[a-z][a-z0-9_]*$"}
          }
        }
      }
    },
    "detectors": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order", "group", "id", "lexical_grammar", "semantic_validator",
          "input_context", "candidate_bound", "replacement_interval", "fixture_set"
        ],
        "properties": {
          "order": {"type": "integer", "minimum": 1, "maximum": 14},
          "group": {"enum": ["credentials", "secrets", "pii"]},
          "id": {"type": "string", "pattern": "^(credentials|secrets|pii)\\.[a-z][a-z0-9_]*$"},
          "lexical_grammar": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "semantic_validator": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "input_context": {"const": "valid_utf8_string_and_field_class"},
          "candidate_bound": {"type": "integer", "minimum": 1, "maximum": 262144},
          "replacement_interval": {"enum": ["candidate", "credential_value", "member_value", "account_component"]},
          "fixture_set": {"type": "string", "pattern": "^[a-z][a-z0-9_]*_v1$"}
        }
      }
    }
  }
}
