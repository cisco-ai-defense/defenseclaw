{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defenseclaw.dev/schemas/otel/runtime-tool-span.schema.json",
  "title": "DefenseClaw Runtime Tool Call Span",
  "description": "OTEL INTERNAL span for a tool invocation. gen_ai.* attributes provide correlation; defenseclaw.* attributes carry enforcement and provenance.",
  "type": "object",
  "required": [
    "name",
    "kind",
    "startTimeUnixNano",
    "attributes"
  ],
  "x-required-attribute-keys": [
    "gen_ai.operation.name",
    "gen_ai.tool.name",
    "openinference.span.kind",
    "gen_ai.tool.call.arguments",
    "gen_ai.tool.call.result",
    "gen_ai.input.messages",
    "gen_ai.output.messages"
  ],
  "x-optional-attribute-keys": [
    "defenseclaw.agent.root.id",
    "defenseclaw.agent.parent.id",
    "defenseclaw.session.root.id",
    "defenseclaw.session.parent.id",
    "defenseclaw.agent.lifecycle.id",
    "defenseclaw.agent.execution.id",
    "defenseclaw.agent.lifecycle.event",
    "defenseclaw.agent.lifecycle.state",
    "defenseclaw.agent.depth",
    "defenseclaw.session.source",
    "defenseclaw.session.resumed",
    "defenseclaw.telemetry.input.reported",
    "defenseclaw.telemetry.output.reported",
    "user.id",
    "defenseclaw.user.name"
  ],
  "x-galileo-exported": true,
  "properties": {
    "traceId": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "spanId": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "parentSpanId": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "name": {
      "type": "string",
      "pattern": "^execute_tool .+$",
      "description": "OTEL GenAI span name: execute_tool {tool_name}.",
      "examples": [
        "execute_tool shell",
        "execute_tool web_search"
      ]
    },
    "kind": {
      "type": "integer",
      "const": 1
    },
    "startTimeUnixNano": {
      "type": "string"
    },
    "endTimeUnixNano": {
      "type": "string"
    },
    "status": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "enum": [
            0,
            1,
            2
          ]
        },
        "message": {
          "type": "string"
        }
      }
    },
    "attributes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attribute"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/spanEvent"
      }
    }
  },
  "$defs": {
    "attribute": {
      "type": "object",
      "required": [
        "key",
        "value"
      ],
      "properties": {
        "key": {
          "type": "string"
        },
        "value": {
          "type": "object"
        }
      }
    },
    "spanEvent": {
      "type": "object",
      "required": [
        "name",
        "timeUnixNano"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "tool.flagged"
          ]
        },
        "timeUnixNano": {
          "type": "string"
        },
        "attributes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attribute"
          }
        }
      }
    },
    "attributeDefinitions": {
      "type": "object",
      "properties": {
        "tenant.id": {
          "type": "string"
        },
        "workspace.id": {
          "type": "string"
        },
        "deployment.environment": {
          "type": "string"
        },
        "deployment.mode": {
          "type": "string"
        },
        "discovery.source": {
          "type": "string"
        },
        "defenseclaw.device.id": {
          "type": "string"
        },
        "gen_ai.operation.name": {
          "type": "string",
          "const": "execute_tool"
        },
        "gen_ai.tool.name": {
          "type": "string"
        },
        "gen_ai.tool.type": {
          "type": "string",
          "const": "function"
        },
        "gen_ai.tool.call.id": {
          "type": "string"
        },
        "openinference.span.kind": {
          "type": "string",
          "const": "TOOL"
        },
        "gen_ai.tool.call.arguments": {
          "type": "string"
        },
        "gen_ai.tool.call.result": {
          "type": "string"
        },
        "gen_ai.input.messages": {
          "type": "string"
        },
        "gen_ai.output.messages": {
          "type": "string"
        },
        "input.value": {
          "type": "string"
        },
        "input.mime_type": {
          "type": "string",
          "const": "application/json"
        },
        "output.value": {
          "type": "string"
        },
        "output.mime_type": {
          "type": "string",
          "const": "text/plain"
        },
        "gen_ai.conversation.id": {
          "type": "string"
        },
        "gen_ai.agent.name": {
          "type": "string"
        },
        "gen_ai.agent.type": {
          "type": "string"
        },
        "gen_ai.agent.id": {
          "type": "string"
        },
        "defenseclaw.agent.root.id": { "type": "string" },
        "defenseclaw.agent.parent.id": { "type": "string" },
        "defenseclaw.session.root.id": { "type": "string" },
        "defenseclaw.session.parent.id": { "type": "string" },
        "defenseclaw.agent.lifecycle.id": { "type": "string" },
        "defenseclaw.agent.execution.id": { "type": "string" },
        "defenseclaw.agent.lifecycle.event": { "type": "string" },
        "defenseclaw.agent.lifecycle.state": { "type": "string" },
        "defenseclaw.agent.depth": { "type": "integer", "minimum": 0 },
        "defenseclaw.session.source": { "type": "string" },
        "defenseclaw.session.resumed": { "type": "boolean" },
        "defenseclaw.telemetry.input.reported": { "type": "boolean" },
        "defenseclaw.telemetry.output.reported": { "type": "boolean" },
        "user.id": { "type": "string" },
        "defenseclaw.user.name": { "type": "string" },
        "defenseclaw.run.id": {
          "type": "string"
        },
        "defenseclaw.agent.instance_id": {
          "type": "string"
        },
        "defenseclaw.destination.app": {
          "type": "string"
        },
        "defenseclaw.policy.id": {
          "type": "string"
        },
        "defenseclaw.tool.status": {
          "type": "string"
        },
        "defenseclaw.tool.args_length": {
          "type": "integer",
          "minimum": 0
        },
        "defenseclaw.tool.args": {
          "type": "string",
          "description": "Raw arguments; emitted only when persistent-sink redaction is explicitly disabled."
        },
        "defenseclaw.tool.exit_code": {
          "type": "integer"
        },
        "defenseclaw.tool.output_length": {
          "type": "integer",
          "minimum": 0
        },
        "defenseclaw.tool.dangerous": {
          "type": "boolean"
        },
        "defenseclaw.tool.flagged_pattern": {
          "type": "string"
        },
        "defenseclaw.tool.provider": {
          "type": "string"
        },
        "defenseclaw.tool.skill_key": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "spanEventAttributeDefinitions": {
      "type": "object",
      "properties": {
        "defenseclaw.flag.reason": {
          "type": "string",
          "const": "dangerous-pattern"
        },
        "defenseclaw.flag.pattern": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
