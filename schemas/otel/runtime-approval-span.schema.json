{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defenseclaw.dev/schemas/otel/runtime-approval-span.schema.json",
  "title": "DefenseClaw Exec Approval Span",
  "description": "OTEL INTERNAL span for an execution approval request and its final resolution.",
  "type": "object",
  "required": ["name", "kind", "startTimeUnixNano", "attributes"],
  "x-required-attribute-keys": [
    "defenseclaw.approval.id",
    "defenseclaw.approval.command_name",
    "defenseclaw.approval.argc",
    "defenseclaw.approval.result"
  ],
  "x-galileo-exported": false,
  "properties": {
    "traceId": { "type": "string", "pattern": "^[0-9a-f]{32}$" },
    "spanId": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
    "parentSpanId": { "type": "string", "pattern": "^[0-9a-f]{16}$" },
    "name": {
      "type": "string",
      "pattern": "^exec\\.approval/.+$",
      "examples": ["exec.approval/approval-1"]
    },
    "kind": { "type": "integer", "const": 1 },
    "startTimeUnixNano": { "type": "string" },
    "endTimeUnixNano": { "type": "string" },
    "status": {
      "type": "object",
      "properties": {
        "code": { "type": "integer", "enum": [0, 1, 2] },
        "message": { "type": "string" }
      }
    },
    "attributes": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribute" }
    }
  },
  "$defs": {
    "attribute": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "object" }
      }
    },
    "attributeDefinitions": {
      "type": "object",
      "properties": {
        "tenant.id": { "type": "string" },
        "workspace.id": { "type": "string" },
        "deployment.environment": { "type": "string" },
        "deployment.mode": { "type": "string" },
        "discovery.source": { "type": "string" },
        "defenseclaw.device.id": { "type": "string" },
        "defenseclaw.approval.id": { "type": "string" },
        "defenseclaw.approval.command_name": { "type": "string" },
        "defenseclaw.approval.argc": { "type": "integer", "minimum": 0 },
        "defenseclaw.approval.command": {
          "type": "string",
          "description": "Raw command; emitted only when persistent-sink redaction is explicitly disabled."
        },
        "defenseclaw.approval.argv": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Raw argv; emitted only when persistent-sink redaction is explicitly disabled."
        },
        "defenseclaw.approval.cwd": {
          "type": "string",
          "description": "Raw working directory; emitted only when persistent-sink redaction is explicitly disabled."
        },
        "defenseclaw.approval.result": {
          "type": "string",
          "enum": ["approved", "denied", "timeout"]
        },
        "defenseclaw.approval.reason": { "type": "string" },
        "defenseclaw.approval.auto": { "type": "boolean" },
        "defenseclaw.approval.dangerous": { "type": "boolean" },
        "gen_ai.tool.call.id": { "type": "string" },
        "gen_ai.conversation.id": { "type": "string" },
        "gen_ai.agent.name": { "type": "string" },
        "gen_ai.agent.type": { "type": "string" },
        "gen_ai.agent.id": { "type": "string" },
        "defenseclaw.run.id": { "type": "string" },
        "defenseclaw.destination.app": { "type": "string" },
        "defenseclaw.policy.id": { "type": "string" },
        "defenseclaw.agent.instance_id": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
