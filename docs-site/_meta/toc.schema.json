{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DefenseClaw docs-site TOC",
  "type": "object",
  "required": ["site", "version", "groups"],
  "properties": {
    "site": { "type": "string" },
    "version": { "type": "integer" },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/group" }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "required": ["slug", "title"],
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" }
      },
      "additionalProperties": false
    },
    "group": {
      "type": "object",
      "required": ["id", "label", "pages"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "path": { "type": "string" },
        "pages": {
          "type": "array",
          "items": { "$ref": "#/$defs/page" }
        },
        "subgroups": {
          "type": "array",
          "items": { "$ref": "#/$defs/group" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
