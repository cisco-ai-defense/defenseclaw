# Generated by `npm run build:policy-assets` — these files are not
# hand-edited. Marking them `linguist-generated=true` collapses them
# in GitHub PR diffs (you can still expand if you actually want to
# inspect a schema change) and prevents the language stats from
# being skewed by large JSON dumps. The build pipeline also no
# longer emits a `generated_at` timestamp, so diffs only show real
# schema/content changes.
data/policy-presets.json    linguist-generated=true
data/policy-recipes.json    linguist-generated=true
data/policy-scenarios.json  linguist-generated=true

# OPA-compiled WebAssembly + its manifest. Binary on the wire, never
# diff-meaningful.
public/opa/*.wasm           binary
public/opa/manifest.json    linguist-generated=true
